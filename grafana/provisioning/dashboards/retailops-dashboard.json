{
  "dashboard": {
    "title": "RetailOps AI 监控面板",
    "tags": ["retailops", "django", "celery"],
    "timezone": "browser",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "🎯 Action Plan 生成成功率",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(rate(retailops_action_plan_created_total{status=\"completed\"}[1h])) / sum(rate(retailops_action_plan_created_total[1h])) * 100",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 6, "w": 4, "x": 0, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 95},
                {"color": "green", "value": 98}
              ]
            }
          }
        },
        "description": "告警阈值: < 95%"
      },
      {
        "id": 2,
        "title": "⏱️ Action Plan 生成耗时 P95",
        "type": "stat",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(retailops_action_plan_generation_seconds_bucket[5m])) by (le))",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 6, "w": 4, "x": 4, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 20},
                {"color": "red", "value": 30}
              ]
            }
          }
        },
        "description": "告警阈值: > 30s"
      },
      {
        "id": 3,
        "title": "🚫 重复反馈拦截（1小时）",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(retailops_feedback_duplicate_blocks_total[1h])) + sum(increase(retailops_feedback_duplicate_warnings_total[1h]))",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 6, "w": 4, "x": 8, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 10},
                {"color": "red", "value": 20}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "⚡ API 响应时间 P95",
        "type": "stat",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(django_http_requests_latency_seconds_by_view_method_bucket{view=\"submit_feedback\"}[5m])) by (le))",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 6, "w": 4, "x": 12, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 3,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1.5},
                {"color": "red", "value": 2}
              ]
            }
          }
        },
        "description": "告警阈值: > 2s"
      },
      {
        "id": 5,
        "title": "📋 Celery 队列积压",
        "type": "stat",
        "targets": [
          {
            "expr": "redis_db_keys{db=\"db0\"}",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 6, "w": 4, "x": 16, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 10},
                {"color": "red", "value": 20}
              ]
            }
          }
        },
        "description": "告警阈值: > 20"
      },
      {
        "id": 6,
        "title": "❌ LLM API 失败率",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(rate(retailops_llm_api_calls_total{status=\"error\"}[1h])) / sum(rate(retailops_llm_api_calls_total[1h])) * 100",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 6, "w": 4, "x": 20, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 3},
                {"color": "red", "value": 5}
              ]
            }
          }
        },
        "description": "告警阈值: > 5%"
      },
      {
        "id": 7,
        "title": "HTTP 请求趋势",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(django_http_requests_total_by_view_transport_method_total[1m]))",
            "refId": "A",
            "legendFormat": "总 QPS"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
        "yaxes": [
          {"format": "reqps", "label": "请求/秒"}
        ]
      },
      {
        "id": 8,
        "title": "LLM API 调用延迟",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(retailops_llm_api_duration_seconds_bucket[5m])) by (le, provider))",
            "refId": "A",
            "legendFormat": "{{provider}} P95"
          },
          {
            "expr": "histogram_quantile(0.50, sum(rate(retailops_llm_api_duration_seconds_bucket[5m])) by (le, provider))",
            "refId": "B",
            "legendFormat": "{{provider}} P50"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
        "yaxes": [
          {"format": "s", "label": "延迟"}
        ]
      },
      {
        "id": 9,
        "title": "5xx 错误率",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(django_http_responses_total_by_status_total{status=~\"5..\"}[5m])) / sum(rate(django_http_responses_total_by_status_total[5m])) * 100",
            "refId": "A",
            "legendFormat": "5xx 错误率"
          }
        ],
        "gridPos": {"h": 7, "w": 8, "x": 0, "y": 14},
        "yaxes": [
          {"format": "percent", "label": "错误率"}
        ],
        "alert": {
          "name": "5xx 错误率告警",
          "conditions": [
            {
              "evaluator": {"params": [1], "type": "gt"},
              "query": {"params": ["A", "5m", "now"]}
            }
          ]
        }
      },
      {
        "id": 10,
        "title": "LLM Token 消耗趋势",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(retailops_llm_tokens_used_total{type=\"prompt\"}[5m])) by (provider)",
            "refId": "A",
            "legendFormat": "{{provider}} Prompt Tokens/s"
          },
          {
            "expr": "sum(rate(retailops_llm_tokens_used_total{type=\"completion\"}[5m])) by (provider)",
            "refId": "B",
            "legendFormat": "{{provider}} Completion Tokens/s"
          }
        ],
        "gridPos": {"h": 7, "w": 8, "x": 8, "y": 14},
        "yaxes": [
          {"format": "short", "label": "Tokens/秒"}
        ]
      },
      {
        "id": 11,
        "title": "Redis 内存使用",
        "type": "gauge",
        "targets": [
          {
            "expr": "redis_memory_used_bytes / redis_memory_max_bytes * 100",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 7, "w": 8, "x": 16, "y": 14},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 70},
                {"color": "red", "value": 85}
              ]
            }
          }
        }
      },
      {
        "id": 12,
        "title": "异常检测详情",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(retailops_feedback_duplicate_blocks_total[5m])) by (category_code)",
            "refId": "A",
            "legendFormat": "{{category_code}} 同日重复(BLOCK)"
          },
          {
            "expr": "sum(rate(retailops_feedback_duplicate_warnings_total[5m])) by (category_code)",
            "refId": "B",
            "legendFormat": "{{category_code}} 跨日重复(WARN)"
          },
          {
            "expr": "sum(rate(retailops_store_name_mismatches_total[5m])) by (store_id)",
            "refId": "C",
            "legendFormat": "门店名称不匹配"
          }
        ],
        "gridPos": {"h": 7, "w": 12, "x": 0, "y": 21}
      },
      {
        "id": 13,
        "title": "数据库查询延迟 P95",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(django_db_query_duration_seconds_bucket[5m])) by (le))",
            "refId": "A",
            "legendFormat": "P95 查询时间"
          }
        ],
        "gridPos": {"h": 7, "w": 12, "x": 12, "y": 21},
        "yaxes": [
          {"format": "s", "label": "延迟"}
        ]
      }
    ],
    "schemaVersion": 27,
    "version": 1
  }
}
